{
  "name": "nc-passwords-mcp",
  "version": "0.1.0",
  "description": "MCP server for Nextcloud Passwords app integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "nc-passwords-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "keywords": [
    "mcp",
    "nextcloud",
    "passwords",
    "ai"
  ],
  "author": "itsablabla",
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "pino": "^10.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
