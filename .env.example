# Required — Nextcloud instance with Passwords app installed
NEXTCLOUD_URL=https://next.garzaos.cloud
NEXTCLOUD_USER=admin
NEXTCLOUD_PASSWORD=your-app-password-here

# Optional — Transport selection
# MCP_TRANSPORT=stdio    # default: stdio for local MCP clients
# MCP_TRANSPORT=http     # Streamable HTTP for remote clients

# Optional — HTTP transport settings
# MCP_PORT=3340
# MCP_HOST=0.0.0.0

# Optional — Logging
# LOG_LEVEL=info          # trace/debug/info/warn/error/fatal
